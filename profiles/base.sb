;; cloudseal base profile — minimum viable sandbox for any AI agent
;; Always loaded. Provides: filesystem read, process exec, temp writes,
;; project writes, and blocks destructive system operations.
;;
;; Parameters injected by wrapper: _HOME, _PROJECT_DIR, _TMPDIR

(version 1)

;; ═══ Default: Deny All ═══
(deny default)

;; ═══ Filesystem: Read Access ═══

;; Read most of the filesystem (runtimes, tools, libraries)
(allow file-read* (subpath "/"))
(allow file-read-metadata (subpath "/"))

;; Terminal control for interactive agent TUIs
(allow pseudo-tty)
(allow file-ioctl
    (literal "/dev/ptmx")
    (literal "/dev/tty")
    (regex #"^/dev/ttys"))
(allow file-read* file-write*
    (literal "/dev/null")
    (literal "/dev/ptmx")
    (literal "/dev/tty")
    (regex #"^/dev/ttys"))

;; ═══ Filesystem: Write Access ═══

;; Write to project directory (with exceptions — see below)
(allow file-write* (subpath "_PROJECT_DIR"))

;; Write to temp directories
(allow file-write* (subpath "_TMPDIR"))
(allow file-write* (subpath "/private/tmp"))
(allow file-write* (subpath "/var/folders"))

;; Write to user cache (package managers need this)
(allow file-write* (subpath "_HOME/.cache"))

;; Gradle builds need user-level cache/native/daemon state under ~/.gradle.
;; Keep persistent Gradle init/config files protected below.
(allow file-write* (subpath "_HOME/.gradle"))

;; Codex runtime state. Keep auth/config/rules read-only below.
(allow file-write* (subpath "_HOME/.codex"))

;; Claude runtime state. Keep settings/plugins/native integration read-only below.
(allow file-write* (subpath "_HOME/.claude"))

;; Grok Build (xAI) runtime state. Keep auth/config/extension points read-only below.
;; Sessions, memory, logs, caches, sockets, and auto-update binaries live under ~/.grok.
(allow file-write* (subpath "_HOME/.grok"))

;; ═══ Filesystem: Protected Write Paths ═══
;; Block writes to dangerous locations even within project dir

;; No writing to .git internals (hooks, config) — prevents persistence
(deny file-write* (subpath "_PROJECT_DIR/.git/hooks"))
(deny file-write* (subpath "_PROJECT_DIR/.git/config"))

;; No writing to IDE/editor configs (prevents agent planting settings)
(deny file-write* (subpath "_PROJECT_DIR/.vscode"))
(deny file-write* (subpath "_PROJECT_DIR/.idea"))

;; No writing to MCP config (prevents agent adding its own tools)
(deny file-write* (subpath "_PROJECT_DIR/.mcp.json"))

;; No writing to Gradle user-level init/config files, which can contain
;; credentials or persistent build logic. Cache/state under ~/.gradle stays
;; writable for normal builds.
(deny file-write* (literal "_HOME/.gradle/gradle.properties"))
(deny file-write* (literal "_HOME/.gradle/init.gradle"))
(deny file-write* (literal "_HOME/.gradle/init.gradle.kts"))
(deny file-write* (subpath "_HOME/.gradle/init.d"))

;; No writing to Codex auth, configuration, or extension points
(deny file-write* (literal "_HOME/.codex/auth.json"))
(deny file-write* (literal "_HOME/.codex/config.toml"))
(deny file-write* (subpath "_HOME/.codex/rules"))
(deny file-write* (subpath "_HOME/.codex/skills"))
(deny file-write* (subpath "_HOME/.codex/memories"))

;; No writing to Claude settings, plugins, native integration, or global state
(deny file-write* (literal "_HOME/.claude/settings.json"))
(deny file-write* (subpath "_HOME/.claude/plugins"))
(deny file-write* (subpath "_HOME/.claude/chrome"))
(deny file-write* (subpath "_HOME/.claude/backups"))
(deny file-write* (literal "_HOME/.claude.json"))

;; No writing to Grok Build auth, configuration, policy, or extension points
(deny file-write* (literal "_HOME/.grok/auth.json"))
(deny file-write* (literal "_HOME/.grok/config.toml"))
(deny file-write* (literal "_HOME/.grok/requirements.toml"))
(deny file-write* (literal "_HOME/.grok/sandbox.toml"))
(deny file-write* (literal "_HOME/.grok/trusted_folders.toml"))
(deny file-write* (literal "_HOME/.grok/settings.json"))
(deny file-write* (subpath "_HOME/.grok/skills"))
(deny file-write* (subpath "_HOME/.grok/plugins"))
(deny file-write* (subpath "_HOME/.grok/hooks"))
(deny file-write* (subpath "_HOME/.grok/installed-plugins"))

;; ═══ Process Execution ═══

;; Allow running any binary (individual profiles may restrict)
(allow process-exec (subpath "/"))
(allow process-fork)

;; ═══ Network ═══

;; Allow all outbound network (API calls, git, package installs)
;; Individual cloud profiles may restrict specific endpoints
(allow network-outbound)
(allow network-inbound)

;; ═══ Browser / OAuth opens ═══
;; CLI agents (Grok Build, Claude Code, Codex, MCP OAuth) open the system
;; browser for login. Without lsopen, Launch Services fails with error -54 and
;; interactive setup can hang with prompts stuck in "queued" while waiting for
;; auth that never completes. This is intentionally narrower than the gui-app
;; profile (no full GUI/GPU stack).
(allow lsopen)

;; ═══ IPC and System ═══

(allow ipc*)
(allow mach*)
(allow signal)
(allow sysctl-read)

;; ═══ Denied: Destructive System Operations ═══

;; No writing to system directories
(deny file-write* (subpath "/etc"))
(deny file-write* (subpath "/usr"))
(deny file-write* (subpath "/bin"))
(deny file-write* (subpath "/sbin"))
(deny file-write* (subpath "/System"))

;; No mounting/unmounting
(deny file-write-mount)
(deny file-write-umount)

;; No kernel extensions
(deny iokit-open)
