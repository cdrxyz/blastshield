#!/usr/bin/env bash
# blastshield — Sandbox AI coding agents with cloud CLI destructive command protection
# Uses macOS sandbox-exec (Seatbelt) to enforce kernel-level restrictions
#
# Usage:
#   blastshield claude --dangerously-skip-permissions
#   blastshield codex
#   blastshield --profile terraform shell
#   blastshield --profile gcp -- claude

set -euo pipefail

readonly VERSION="0.1.14"
readonly SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
readonly PROFILES_DIR="${SCRIPT_DIR}/profiles"
readonly GUARD_SCRIPT="${SCRIPT_DIR}/helpers/blastshield-guard"
BLASTSHIELD_TMP_PROFILE=""
BLASTSHIELD_TMP_GUARD_DIR=""
BLASTSHIELD_TMP_SHELL_ENV_DIR=""

# Colors (disabled if not a terminal)
if [[ -t 1 ]]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    CYAN='\033[0;36m'
    NC='\033[0m'
else
    RED='' GREEN='' YELLOW='' CYAN='' NC=''
fi

# ─── Default Configuration ───────────────────────────────────────────────

# Default profiles: always loaded for baseline protection
DEFAULT_PROFILES=("base" "secrets")

# Cloud profiles: loaded when cloud CLIs are detected or specified
CLOUD_PROFILES=("terraform" "gcloud" "aws" "azure" "kubectl" "gh" "install")

# ─── Helpers ──────────────────────────────────────────────────────────────

info()  { echo -e "${CYAN}[blastshield]${NC} $*"; }
warn()  { echo -e "${YELLOW}[blastshield]${NC} $*"; }
error() { echo -e "${RED}[blastshield]${NC} $*" >&2; }
die()   { error "$@"; exit 1; }

cleanup() {
    if [[ -n "${BLASTSHIELD_TMP_PROFILE:-}" ]]; then
        rm -f "$BLASTSHIELD_TMP_PROFILE"
    fi
    if [[ -n "${BLASTSHIELD_TMP_GUARD_DIR:-}" ]]; then
        rm -rf "$BLASTSHIELD_TMP_GUARD_DIR"
    fi
    if [[ -n "${BLASTSHIELD_TMP_SHELL_ENV_DIR:-}" ]]; then
        rm -rf "$BLASTSHIELD_TMP_SHELL_ENV_DIR"
    fi
}

# ─── Profile Assembly ────────────────────────────────────────────────────

sed_escape_replacement() {
    printf '%s' "$1" | sed -e 's/[\/&]/\\&/g'
}

# Resolve a profile name to its file path
resolve_profile() {
    local name="$1"
    local path="${PROFILES_DIR}/${name}.sb"

    # Check built-in profiles first
    if [[ -f "$path" ]]; then
        echo "$path"
        return 0
    fi

    # Check absolute/relative paths
    if [[ -f "$name" ]]; then
        echo "$(cd "$(dirname "$name")" && pwd)/$(basename "$name")"
        return 0
    fi

    # Check XDG config
    if [[ -f "${HOME}/.config/blastshield/profiles/${name}.sb" ]]; then
        echo "${HOME}/.config/blastshield/profiles/${name}.sb"
        return 0
    fi

    return 1
}
# Resolve a macOS .app bundle to its actual executable
resolve_app_bundle() {
    local app_path="$1"

    # Remove trailing slash if present
    app_path="${app_path%/}"

    # Prefer the bundle-declared executable. App names and executable names
    # can differ in case or spelling, and GUI apps may inspect argv[0].
    local bundle_exec=""
    if [[ -f "${app_path}/Contents/Info.plist" ]] && command -v /usr/libexec/PlistBuddy &>/dev/null; then
        bundle_exec=$(/usr/libexec/PlistBuddy -c 'Print :CFBundleExecutable' "${app_path}/Contents/Info.plist" 2>/dev/null || true)
        if [[ -n "$bundle_exec" ]]; then
            local plist_exec_path="${app_path}/Contents/MacOS/${bundle_exec}"
            if [[ -x "$plist_exec_path" ]]; then
                echo "$plist_exec_path"
                return 0
            fi
        fi
    fi

    # Construct the executable path inside the bundle
    local exec_path="${app_path}/Contents/MacOS/$(basename "${app_path%.*}")"

    # Check if the executable exists
    if [[ -x "$exec_path" ]]; then
        echo "$exec_path"
        return 0
    fi

    # Fallback: find any executable in MacOS directory
    if [[ -d "${app_path}/Contents/MacOS" ]]; then
        local found
        found=$(find "${app_path}/Contents/MacOS" -type f -perm +111 -print -quit 2>/dev/null)
        if [[ -n "$found" ]]; then
            echo "$found"
            return 0
        fi
    fi

    return 1
}

app_bundle_identifier() {
    local app_path="$1"
    app_path="${app_path%/}"

    if [[ -f "${app_path}/Contents/Info.plist" ]] && command -v /usr/libexec/PlistBuddy &>/dev/null; then
        /usr/libexec/PlistBuddy -c 'Print :CFBundleIdentifier' "${app_path}/Contents/Info.plist" 2>/dev/null || true
    fi
}

is_conductor_app_bundle() {
    local bundle_id
    bundle_id=$(app_bundle_identifier "$1")
    [[ "$bundle_id" == "com.conductor.app" ]]
}


# Detect which cloud CLIs are available on this system
detect_cloud_clis() {
    local detected=()
    for cli in terraform gcloud aws az kubectl gh npm yarn pnpm pip brew gem cargo hermit; do
        if command -v "$cli" &>/dev/null; then
            detected+=("$cli")
        fi
    done

    # If launching a GUI app via 'open /path/to/App.app', auto-add gui-app profile
    if [[ ${#command_args[@]} -ge 2 ]] && [[ "${command_args[0]}" == "open" ]] && [[ "${command_args[1]}" == *.app ]]; then
        local app_path="${command_args[1]}"
        if resolved=$(resolve_app_bundle "$app_path" 2>/dev/null); then
            info "Detected .app bundle — auto-adding 'gui-app' profile and bypassing 'open'"
            # Add gui-app to profiles if not already present
            local already_has_gui=false
            for p in "${extra_profiles[@]:-}"; do
                [[ "$p" == "gui-app" ]] && already_has_gui=true && break
            done
            if ! $already_has_gui; then
                extra_profiles+=("gui-app")
            fi
            # Rewrite command: drop 'open', use resolved binary directly
            command_args=("$resolved" "${command_args[@]:2}")
        else
            warn "Could not resolve .app bundle: $app_path — proceeding without 'gui-app' profile (may fail)"
        fi
    fi
    echo "${detected[*]-}"
}

# Auto-detect relevant cloud profiles based on directory contents
detect_cloud_profiles() {
    local dir="${1:-$(pwd)}"
    local profiles=()

    # Terraform: .tf files
    if find "$dir" -maxdepth 2 -name "*.tf" -print -quit 2>/dev/null | grep -q .; then
        profiles+=("terraform")
    fi

    # GCP: .gcloudignore, cloudbuild.yaml, app.yaml
    if find "$dir" -maxdepth 2 \( -name ".gcloudignore" -o -name "cloudbuild.yaml" -o -name "app.yaml" \) -print -quit 2>/dev/null | grep -q .; then
        profiles+=("gcloud")
    fi

    # AWS: serverless.yml, sam.yaml, cdk.json, template.yaml
    if find "$dir" -maxdepth 2 \( -name "serverless.yml" -o -name "template.yaml" -o -name "cdk.json" -o -name "samconfig.toml" \) -print -quit 2>/dev/null | grep -q .; then
        profiles+=("aws")
    fi

    # Azure: azure-pipelines.yml, function.json, local.settings.json
    if find "$dir" -maxdepth 2 \( -name "azure-pipelines.yml" -o -name "local.settings.json" \) -print -quit 2>/dev/null | grep -q .; then
        profiles+=("azure")
    fi

    # Kubernetes: k8s/, kustomization.yaml, helm/Chart.yaml
    if find "$dir" -maxdepth 3 \( -name "kustomization.yaml" -o -name "Chart.yaml" -o -name "skaffold.yaml" \) -print -quit 2>/dev/null | grep -q .; then
        profiles+=("kubectl")
    fi

    # GitHub: .github/ directory
    if [[ -d "$dir/.github" ]]; then
        profiles+=("gh")
    fi

    # Install: package manifests indicate dependency management
    if find "$dir" -maxdepth 2 \( -name "package.json" -o -name "requirements.txt" -o -name "Pipfile" -o -name "pyproject.toml" -o -name "Gemfile" -o -name "Cargo.toml" -o -name "go.mod" -o -name ".hermit" \) -print -quit 2>/dev/null | grep -q .; then
        profiles+=("install")
    fi

    echo "${profiles[*]:-}"
}

# Assemble a combined sandbox profile from multiple source profiles
assemble_profile() {
    local output_file="$1"
    shift
    local profile_names=("$@")
    local home_dir project_dir tmp_dir
    home_dir="$(cd "$HOME" && pwd -P)"
    project_dir="$(pwd -P)"
    tmp_dir="$(cd "${TMPDIR:-/tmp}" && pwd -P)"

    local home_replacement project_replacement tmp_replacement
    home_replacement="$(sed_escape_replacement "$home_dir")"
    project_replacement="$(sed_escape_replacement "$project_dir")"
    tmp_replacement="$(sed_escape_replacement "$tmp_dir")"

    {
        # Header
        echo ";; blastshield assembled profile — auto-generated, do not edit"
        echo ";; Generated: $(date -u +"%Y-%m-%dT%H:%M:%SZ")"
        echo ";; Profiles: ${profile_names[*]}"
        echo ""

        # Version directive (required by sandbox-exec)
        echo "(version 1)"
        echo ""

        # Deny everything by default — whitelist model
        echo ";; ═══ Default Policy: Deny All ═══"
        echo "(deny default)"
        echo ""

        for name in "${profile_names[@]}"; do
            local path
            if ! path=$(resolve_profile "$name"); then
                warn "Profile not found: $name (skipping)"
                continue
            fi

            echo ";; ═══ Profile: $name ═══"
            echo ";; Source: $path"
            echo ""

            # Strip the (version 1) line from included profiles — we already emitted it
            # Also strip (deny default) from included profiles — base handles it
            sed -E '/^\(version 1\)$/d; /^\(deny default\)$/d; /^;; .*Profile:/d' "$path" |
                sed -e "s/_HOME/$home_replacement/g" \
                    -e "s/_PROJECT_DIR/$project_replacement/g" \
                    -e "s/_TMPDIR/$tmp_replacement/g"

            echo ""
        done

    } > "$output_file"
}

# ─── Sandbox Execution ───────────────────────────────────────────────────

run_sandboxed() {
    local profile_file="$1"
    shift
    local command=("$@")

    if [[ ${#command[@]} -eq 0 ]]; then
        command=("$SHELL")
    fi

    if ! command -v sandbox-exec &>/dev/null; then
        die "sandbox-exec not found. This tool requires macOS."
    fi

    info "Launching in sandbox with profile: $(basename "$profile_file")"
    info "Command: ${command[*]}"

    # Run the command inside the sandbox
    sandbox-exec -f "$profile_file" -- "${command[@]}"
    local exit_code=$?

    if [[ $exit_code -ne 0 ]]; then
        warn "Process exited with code $exit_code"
    fi

    return $exit_code
}

run_sandboxed_gui_app() {
    local profile_file="$1"
    local detach_requested="$2"
    shift 2
    local command=("$@")

    if [[ ${#command[@]} -eq 0 ]]; then
        die "GUI app launch requires a command"
    fi

    if ! command -v sandbox-exec &>/dev/null; then
        die "sandbox-exec not found. This tool requires macOS."
    fi

    local log_file app_pid guard_dir shell_env_dir profile_cleanup
    log_file=$(mktemp "${TMPDIR:-/tmp}/blastshield.gui-app.log.XXXXXX")
    guard_dir="${BLASTSHIELD_TMP_GUARD_DIR:-}"
    shell_env_dir="${BLASTSHIELD_TMP_SHELL_ENV_DIR:-}"
    profile_cleanup="$profile_file"

    info "Launching GUI app in sandbox with profile: $(basename "$profile_file")"
    info "Command: ${command[*]}"

    sandbox-exec -f "$profile_file" -- "${command[@]}" >>"$log_file" 2>&1 &
    app_pid=$!
    sleep 0.2

    if [[ -z "$app_pid" ]] || ! kill -0 "$app_pid" 2>/dev/null; then
        warn "GUI app exited before launch completed; logs: $log_file"
        return 1
    fi

    info "GUI app launched in sandbox as PID $app_pid"
    info "GUI app logs: $log_file"

    if [[ -n "$profile_cleanup" || -n "$guard_dir" || -n "$shell_env_dir" ]]; then
        (
            while kill -0 "$app_pid" 2>/dev/null; do
                sleep 5
            done
            [[ -n "$profile_cleanup" ]] && rm -f "$profile_cleanup"
            [[ -n "$guard_dir" ]] && rm -rf "$guard_dir"
            [[ -n "$shell_env_dir" ]] && rm -rf "$shell_env_dir"
        ) >/dev/null 2>&1 &

        BLASTSHIELD_TMP_PROFILE=""
        BLASTSHIELD_TMP_GUARD_DIR=""
        BLASTSHIELD_TMP_SHELL_ENV_DIR=""
    fi

    if [[ "$detach_requested" != true && "${BLASTSHIELD_GUI_DETACH:-}" != "1" && -t 1 ]]; then
        info "Streaming GUI app logs; press Ctrl-C to stop following (app keeps running)"

        local tail_pid follow_interrupted
        follow_interrupted=false
        touch "$log_file"
        tail -n +1 -f "$log_file" &
        tail_pid=$!

        trap 'follow_interrupted=true; [[ -n "${tail_pid:-}" ]] && kill "$tail_pid" 2>/dev/null || true' INT TERM
        while kill -0 "$app_pid" 2>/dev/null && ! $follow_interrupted; do
            sleep 1 || true
        done
        [[ -n "${tail_pid:-}" ]] && kill "$tail_pid" 2>/dev/null || true
        wait "$tail_pid" 2>/dev/null || true
        trap - INT TERM

        if $follow_interrupted && kill -0 "$app_pid" 2>/dev/null; then
            info "Stopped following GUI app logs; app is still running as PID $app_pid"
        elif ! kill -0 "$app_pid" 2>/dev/null; then
            info "GUI app exited; logs retained at: $log_file"
        fi
    fi
}

setup_runtime_guards() {
    if [[ ! -x "$GUARD_SCRIPT" ]]; then
        warn "blastshield-guard not found; command-argument filtering disabled"
        return 0
    fi

    local target_dir
    target_dir=$(mktemp -d "${TMPDIR:-/tmp}/blastshield.guard.XXXXXX")
    BLASTSHIELD_TMP_GUARD_DIR="$target_dir"

    BLASTSHIELD_GUARD_INSTALL_QUIET=1 "$GUARD_SCRIPT" install "$target_dir"

    if find "$target_dir" -maxdepth 1 -type f -print -quit 2>/dev/null | grep -q .; then
        export PATH="$target_dir:$PATH"
        export BLASTSHIELD_GUARD_MODE="block"
    else
        rm -rf "$target_dir"
        BLASTSHIELD_TMP_GUARD_DIR=""
    fi
}

setup_gui_shell_env() {
    if [[ -z "${BLASTSHIELD_TMP_GUARD_DIR:-}" ]]; then
        return 0
    fi

    local target_dir guard_dir guard_dir_quoted
    target_dir=$(mktemp -d "${TMPDIR:-/tmp}/blastshield.shell-env.XXXXXX")
    BLASTSHIELD_TMP_SHELL_ENV_DIR="$target_dir"
    guard_dir="$BLASTSHIELD_TMP_GUARD_DIR"
    printf -v guard_dir_quoted '%q' "$guard_dir"

    local zsh_files=(.zshenv .zprofile .zshrc .zlogin)
    local zsh_file
    for zsh_file in "${zsh_files[@]}"; do
        {
            echo "# Generated by blastshield for GUI app PATH discovery."
            echo "if [ -f \"\$HOME/$zsh_file\" ]; then"
            echo "    . \"\$HOME/$zsh_file\""
            echo "fi"
            printf 'PATH=%s:"$PATH"\n' "$guard_dir_quoted"
            echo "export PATH"
        } > "$target_dir/$zsh_file"
    done

    export ZDOTDIR="$target_dir"
}

# ─── Diagnostics ──────────────────────────────────────────────────────────

show_violations() {
    info "Recent sandbox violations (last 5 minutes):"
    log show --predicate 'subsystem == "com.apple.sandbox"' --last 5m 2>/dev/null || \
        warn "Could not read system log (may need Full Disk Access in System Settings)"
}

show_status() {
    local cloud_clis
    cloud_clis=$(detect_cloud_clis)
    local cloud_profiles
    cloud_profiles=$(detect_cloud_profiles)

    echo -e "${CYAN}blastshield v${VERSION}${NC}"
    echo ""
    echo "Available cloud CLIs:"
    for cli in $cloud_clis; do
        local path
        path=$(command -v "$cli")
        echo "  ✅ $cli → $path"
    done
    echo ""
    echo "Detected project profiles:"
    for profile in $cloud_profiles; do
        echo "  🔒 $profile"
    done
    echo ""
    echo "Built-in profiles:"
    for f in "$PROFILES_DIR"/*.sb; do
        [[ -f "$f" ]] && echo "  📄 $(basename "$f" .sb)"
    done
}

# ─── Main ─────────────────────────────────────────────────────────────────

main() {
    local profiles=("${DEFAULT_PROFILES[@]}")
    local extra_profiles=()
    local clean_env=false
    local guard_enabled=true
    auto_detect=true
    local verbose=false
    local diagnostic_mode=""
    local command_args=()
    local gui_app_launch=false
    local gui_detach=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -p|--profile)
                [[ $# -lt 2 ]] && die "--profile requires an argument"
                extra_profiles+=("$2")
                shift 2
                ;;
            --no-detect)
                auto_detect=false
                shift
                ;;
            --no-guard)
                guard_enabled=false
                shift
                ;;
            --detach)
                gui_detach=true
                shift
                ;;
            -c|--clean-env)
                clean_env=true
                shift
                ;;
            -v|--verbose)
                verbose=true
                shift
                ;;
            --violations)
                diagnostic_mode="violations"
                shift
                ;;
            --status)
                diagnostic_mode="status"
                shift
                ;;
            --version)
                echo "blastshield v${VERSION}"
                exit 0
                ;;
            -h|--help)
                cat <<'HELP'
blastshield — Sandbox AI coding agents with cloud CLI destructive command protection

USAGE:
    blastshield [OPTIONS] [--] COMMAND [ARGS...]

OPTIONS:
    -p, --profile NAME    Load additional profile (repeatable)
                          Built-in: terraform, gcloud, aws, azure, kubectl, gh
    --no-guard            Disable automatic command-argument guard injection
    --no-detect           Disable auto-detection of cloud profiles
    --detach              For GUI app launches, return immediately instead of streaming logs
    -c, --clean-env       Strip environment variables (removes API keys from env)
    -v, --verbose         Verbose output
    --violations         Show recent sandbox violations from system log
    --status             Show detected CLIs and profiles
    --version            Show version
    -h, --help           Show this help

EXAMPLES:
    # Run Claude Code with all auto-detected protections
    blastshield claude --dangerously-skip-permissions

    # Run Codex with explicit terraform profile
    blastshield -p terraform codex

    # Run a shell with GCP and AWS profiles
    blastshield -p gcloud -p aws bash

    # Check what profiles would be loaded for current directory
    blastshield --status

    # View recent sandbox violations
    blastshield --violations

PROFILES:
    Profiles are loaded in order. Later profiles can narrow earlier ones.
    Default profiles (always loaded): base, secrets
    Cloud profiles (auto-detected or explicit): terraform, gcloud, aws, azure, kubectl, gh
    Install profiles (auto-detected): install
    GUI profiles (auto-detected): gui-app, conductor-app for com.conductor.app

    Compose with existing tools:
    blastshield -p terraform -- safehouse claude --dangerously-skip-permissions

LAYERING:
    blastshield (OS-level, cloud CLI policy)
      └── safehouse/seatbelt (OS-level, file policy)
          └── agent's built-in sandbox (tool-level)
              └── your agent process
HELP
                exit 0
                ;;
            --)
                shift
                command_args=("$@")
                break
                ;;
            -*)
                die "Unknown option: $1 (use -- to separate options from command)"
                ;;
            *)
                command_args=("$@")
                break
                ;;
        esac
    done

    # If launching a GUI app via 'open /path/to/App.app', auto-add gui-app profile
    if [[ ${#command_args[@]} -ge 2 ]] && [[ "${command_args[0]}" == "open" ]] && [[ "${command_args[1]}" == *.app ]]; then
        local app_path="${command_args[1]}"
        if resolved=$(resolve_app_bundle "$app_path" 2>/dev/null); then
            info "Detected .app bundle — auto-adding 'gui-app' profile and bypassing 'open'"
            # Add gui-app to profiles if not already present
            local already_has_gui=false
            for p in "${extra_profiles[@]:-}"; do
                [[ "$p" == "gui-app" ]] && already_has_gui=true && break
            done
            if ! $already_has_gui; then
                extra_profiles+=("gui-app")
            fi
            if is_conductor_app_bundle "$app_path"; then
                local already_has_conductor=false
                for p in "${extra_profiles[@]:-}"; do
                    [[ "$p" == "conductor-app" ]] && already_has_conductor=true && break
                done
                if ! $already_has_conductor; then
                    extra_profiles+=("conductor-app")
                    info "Detected Conductor app — auto-adding 'conductor-app' profile"
                fi
            fi
            gui_app_launch=true
            # Rewrite command: drop 'open', use resolved binary directly
            command_args=("$resolved" "${command_args[@]:2}")
        else
            warn "Could not resolve .app bundle: $app_path — proceeding without 'gui-app' profile (may fail)"
        fi
    fi

    # When launching a GUI app, skip the 'secrets' profile — GUI apps need
    # normal system access (including CLI tools like gh) and the user is
    # directly invoking a known app, so the exfiltration threat model differs
    # from AI agent runs. The gui-app profile already confines writes to
    # user-level directories.
    if $gui_app_launch; then
        local filtered_profiles=()
        for p in "${profiles[@]}"; do
            [[ "$p" != "secrets" ]] && filtered_profiles+=("$p")
        done
        profiles=("${filtered_profiles[@]}")
        info "GUI app launch: skipping 'secrets' profile to allow normal system access"
    fi

    # Handle diagnostic modes
    if [[ -n "$diagnostic_mode" ]]; then
        case "$diagnostic_mode" in
            violations) show_violations; exit 0 ;;
            status) show_status; exit 0 ;;
        esac
    fi

    # Auto-detect cloud profiles from current directory. GUI app launches run
    # long-lived user apps whose startup checks often need normal CLI auth
    # config (for example gh hosts.yml), so only explicit profiles apply there.
    if $auto_detect && $gui_app_launch; then
        info "GUI app launch: skipping project profile auto-detection; use -p to opt into specific profiles"
    elif $auto_detect && [[ ${#command_args[@]} -gt 0 ]]; then
        local detected
        detected=$(detect_cloud_profiles)
        for profile in $detected; do
            local already_selected=false
            if [[ ${#extra_profiles[@]} -gt 0 ]]; then
                local existing_profile
                for existing_profile in "${extra_profiles[@]}"; do
                    if [[ "$existing_profile" == "$profile" ]]; then
                        already_selected=true
                        break
                    fi
                done
            fi

            if ! $already_selected; then
                extra_profiles+=("$profile")
                $verbose && info "Auto-detected profile: $profile"
            fi
        done
    fi

    # Assemble full profile list
    if [[ ${#extra_profiles[@]} -gt 0 ]]; then
        profiles+=("${extra_profiles[@]}")
    fi

    $verbose && info "Profiles: ${profiles[*]}"

    # Create temporary assembled profile
    local tmp_profile
    tmp_profile=$(mktemp "${TMPDIR:-/tmp}/blastshield.sb.XXXXXX")
    BLASTSHIELD_TMP_PROFILE="$tmp_profile"
    trap cleanup EXIT

    assemble_profile "$tmp_profile" "${profiles[@]}"

    $verbose && info "Assembled profile: $tmp_profile"

    if $guard_enabled; then
        setup_runtime_guards

        if $gui_app_launch; then
            setup_gui_shell_env
        fi

        $verbose && [[ -n "${BLASTSHIELD_TMP_GUARD_DIR:-}" ]] && info "Runtime guard: $BLASTSHIELD_TMP_GUARD_DIR"
    fi


    # Clean environment if requested
    if $clean_env; then
        # Build a sanitized environment
        local safe_env_vars=(
            HOME PATH SHELL TERM LANG USER TMPDIR
            ZDOTDIR
            SSH_AUTH_SOCK EDITOR VISUAL
            XDG_CACHE_HOME XDG_CONFIG_HOME XDG_DATA_HOME XDG_STATE_HOME
            BLASTSHIELD_GUARD_MODE
            ANTHROPIC_BASE_URL OPENAI_BASE_URL GOOGLE_BASE_URL
            # Cloud SDK base URLs (safe, not secrets)
            AWS_DEFAULT_REGION AWS_REGION
            CLOUDSDK_CORE_PROJECT CLOUDSDK_COMPUTE_ZONE
            AZURE_DEFAULTS_LOCATION AZURE_DEFAULTS_GROUP
        )

        local env_args=()
        for var in "${safe_env_vars[@]}"; do
            if [[ -n "${!var:-}" ]]; then
                env_args+=("$var=${!var}")
            fi
        done

        # Run with cleaned env inside sandbox
        env -i "${env_args[@]}" run_sandboxed "$tmp_profile" "${command_args[@]}"
    else
        if $gui_app_launch; then
            run_sandboxed_gui_app "$tmp_profile" "$gui_detach" "${command_args[@]}"
        else
            run_sandboxed "$tmp_profile" "${command_args[@]}"
        fi
    fi
}

main "$@"
