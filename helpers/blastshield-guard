#!/usr/bin/env bash
# blastshield-guard — Command-level guard for mutating cloud CLI subcommands
#
# PHILOSOPHY: Only read operations pass through automatically. ANY command
# that mutates cloud resources (apply, deploy, create, delete, update, etc.)
# requires biometric/password authentication. The AI agent should prompt
# the user to run mutating commands manually.
#
# sandbox-exec operates at the file/process level and cannot filter by
# command arguments. This script provides command-argument-level filtering
# as a complement to sandbox-exec profiles.
#
# Usage:
#   1. Add to PATH before real CLIs: export PATH="$HOME/.blastshield/guard:$PATH"
#   2. Symlinks auto-generated: blastshield-guard install
#   3. Each guarded CLI gets a wrapper that blocks mutating subcommands
#
# The wrapper prompts for Touch ID / sudo password before allowing
# mutating operations, then executes with normal (non-root) permissions.

set -euo pipefail

readonly GUARD_DIR="$(cd "$(dirname "$0")" && pwd)"
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly CYAN='\033[0;36m'
readonly NC='\033[0m'

# ─── Command Definitions ──────────────────────────────────────────────
# Two lists: READ-ONLY patterns (pass through) and everything else (blocked)
# Format: CLI_NAME:PATTERNS (colon-separated, space-delimited groups)
# Patterns support glob matching via case

# Read-only subcommands that are always allowed (no auth required)
# Use underscore _ instead of space in multi-word patterns (e.g., "state_list")
# The matcher converts both pattern and subcommand to use _ for comparison
READONLY_PATTERNS="\
terraform:init,plan,fmt,validate,show,output,console,state_list,state_show,workspace_list,workspace_select,providers,version,graph \
gcloud:list,describe,get,print-access-token,auth,status,version,config,help \
aws:ec2_describe-*,ec2_list-*,s3_ls*,s3_cp*,s3_presign*,sts_get-caller-identity,logs_describe-*,logs_get-*,logs_filter-log-events,cloudformation_validate-template,dynamodb_scan*,dynamodb_query*,dynamodb_get-item,iam_list-*,iam_get-*,lambda_list-*,lambda_invoke* \
az:list,show,version,help,account_show,account_list,find \
kubectl:get,describe,logs,top,events,api-resources,api-versions,explain,auth_can-i,config_view,config_get-contexts,rollout_status,rollout_history,version \
gh:list,view,repo_clone,repo_fork,repo_view,pr_list,pr_view,pr_diff,pr_checkout,issue_list,issue_view,release_list,release_view,release_download,workflow_list,workflow_view,auth_status,api_graphql,help,version \
helm:list,status,history,show,search,version,repo_list,repo_update"

# Mutating subcommands that require biometric auth
# These are the most common dangerous patterns — anything NOT in readonly above
# is treated as mutating by default, but we list explicit patterns for documentation
MUTATING_PATTERNS="\
terraform:apply,destroy,import,taint,untaint,refresh,state_rm,state_mv,workspace_delete,workspace_new \
gcloud:delete,create,deploy,update,add,remove,patch,set,reset,restart,resize,enable,disable,submit,cancel \
aws:ec2_terminate,ec2_run-,ec2_start-instances,ec2_stop-instances,ec2_reboot,s3_rb,s3_rm,s3_mb,s3api_delete,s3api_create,cloudformation_delete,cloudformation_create,cloudformation_update,dynamodb_delete,dynamodb_create,iam_delete,iam_create,iam_put,lambda_delete,lambda_create,lambda_update,rds_delete,rds_create,eks_delete,eks_create,secretsmanager_delete,secretsmanager_create,secretsmanager_put \
az:delete,create,update,deploy,set,remove,add,lock,unlock,scale,restart \
kubectl:apply,create,delete,patch,scale,taint,cordon,uncordon,drain,rollout_restart,rollout_undo,exec,label,annotate,set,expose,port-forward,run,cp,debug \
gh:delete,merge,close,edit,rename,sync,run_cancel,workflow_disable,workflow_enable \
helm:install,upgrade,delete,rollback,uninstall,push"

# ─── Helper Functions ─────────────────────────────────────────────────────

info()  { echo -e "${CYAN}[blastshield-guard]${NC} $*"; }
warn()  { echo -e "${YELLOW}[blastshield-guard]${NC} $*"; }
error() { echo -e "${RED}[blastshield-guard]${NC} $*" >&2; }

# Get the read-only patterns for a CLI
get_readonly_patterns() {
    local cli="$1"
    local group
    for group in $READONLY_PATTERNS; do
        local name="${group%%:*}"
        local patterns="${group#*:}"
        if [[ "$name" == "$cli" ]]; then
            echo "$patterns"
            return 0
        fi
    done
    return 1
}

# Get the mutating patterns for a CLI
get_mutating_patterns() {
    local cli="$1"
    local group
    for group in $MUTATING_PATTERNS; do
        local name="${group%%:*}"
        local patterns="${group#*:}"
        if [[ "$name" == "$cli" ]]; then
            echo "$patterns"
            return 0
        fi
    done
    return 1
}

# Extract the subcommand from args (skip flags, handle multi-word subcommands)
# For two-level CLIs (aws, az, gcloud), returns "service operation" combined
get_subcommand() {
    local args=("$@")
    local i=0
    local words=()
    while [[ $i -lt ${#args[@]} ]]; do
        case "${args[$i]}" in
            --*=*)
                # --flag=value style, skip
                ;;
            --)
                # End of flags
                ((i++))
                if [[ $((i)) -lt ${#args[@]} ]]; then
                    words+=("${args[$i]}")
                fi
                break
                ;;
            -*)
                # Flag, skip it and possibly its argument
                if [[ $((i + 1)) -lt ${#args[@]} ]] && [[ "${args[$((i+1))]}" != -* ]]; then
                    ((i++))
                fi
                ;;
            *)
                # Non-flag word — collect all words for subcommand matching
                words+=("${args[$i]}")
                ;;
        esac
        ((i++))
    done

    # Return the subcommand string (all non-flag words joined with spaces)
    if [[ ${#words[@]} -eq 0 ]]; then
        echo ""
    else
        local result="${words[0]}"
        local w
        for w in "${words[@]:1}"; do
            result="$result $w"
        done
        echo "$result"
    fi
}
# Check if a subcommand matches any pattern in a comma-separated list
# Supports glob matching: "describe-*" matches "describe-instances"
# Spaces in subcommands are normalized to underscores for matching
# Also tries matching just the first word (operation) if full match fails
matches_pattern() {
    local subcmd="$1"
    local patterns="$2"

    # Normalize spaces to underscores for consistent matching
    subcmd="${subcmd// /_}"

    # Save and restore IFS
    local IFS_OLD="$IFS"
    IFS=','
    local pattern
    for pattern in $patterns; do
        IFS="$IFS_OLD"
        # Trim whitespace
        pattern=$(echo "$pattern" | xargs)
        [[ -z "$pattern" ]] && continue
        # Glob matching via case
        case "$subcmd" in
            $pattern)
                IFS="$IFS_OLD"
                return 0
                ;;
        esac
    done

    # If subcmd contains underscore (was multi-word), try matching just the first word
    # e.g., "get_pods" → try "get" against patterns
    # Also try the last word for gcloud-style CLIs where verb comes last
    # e.g., "compute_instances_list" → try "list" against patterns
    if [[ "$subcmd" == *_* ]]; then
        local first_word="${subcmd%%_*}"
        local last_word="${subcmd##*_}"
        IFS=','
        for pattern in $patterns; do
            IFS="$IFS_OLD"
            pattern=$(echo "$pattern" | xargs)
            [[ -z "$pattern" ]] && continue
            case "$first_word" in
                $pattern)
                    IFS="$IFS_OLD"
                    return 0
                    ;;
            esac
            case "$last_word" in
                $pattern)
                    IFS="$IFS_OLD"
                    return 0
                    ;;
            esac
        done
    fi

    IFS="$IFS_OLD"
    return 1
}

# Check if a command is read-only (allowed without auth)
is_readonly() {
    local cli="$1"
    shift
    local subcmd
    subcmd=$(get_subcommand "$@")

    [[ -z "$subcmd" ]] && return 1

    local patterns
    patterns=$(get_readonly_patterns "$cli") || return 1

    matches_pattern "$subcmd" "$patterns"
}

# Check if a command is mutating (requires auth)
is_mutating() {
    local cli="$1"
    shift
    local subcmd
    subcmd=$(get_subcommand "$@")

    [[ -z "$subcmd" ]] && return 1

    # First check if it's explicitly read-only
    if is_readonly "$cli" "$@"; then
        return 1
    fi

    # If we have explicit mutating patterns, check those
    local patterns
    if patterns=$(get_mutating_patterns "$cli") 2>/dev/null; then
        if matches_pattern "$subcmd" "$patterns"; then
            return 0
        fi
    fi

    # Default: if the CLI is guarded but subcmd isn't in readonly list, block it
    # This is the "default deny" posture — anything not explicitly allowed is blocked
    if get_readonly_patterns "$cli" >/dev/null 2>&1; then
        # This CLI has patterns defined but subcmd isn't readonly → treat as mutating
        return 0
    fi

    return 1
}

# Require biometric/password authentication
require_auth() {
    local cli="$1"
    shift
    local args=("$@")

    echo -e "${RED}⛔ BLOCKED: Mutating command detected${NC}"
    echo -e "${RED}   $cli ${args[*]}${NC}"
    echo ""
    echo -e "${YELLOW}Only read-only commands are allowed without authentication.${NC}"

    if [[ "${BLASTSHIELD_GUARD_MODE:-sudo}" == "block" ]]; then
        echo -e "${YELLOW}BlastShield runtime guard is active; run this command yourself outside the agent sandbox.${NC}"
        exit 1
    fi

    echo -e "${YELLOW}Authenticate to proceed, or Ctrl+C to cancel.${NC}"
    echo -e "${YELLOW}Consider running this command yourself instead.${NC}"
    echo ""

    # Force fresh authentication (Touch ID or password)
    sudo -k 2>/dev/null
    if ! sudo -v 2>/dev/null; then
        error "Authentication failed. Command blocked."
        exit 1
    fi

    # Authenticated — allow through
    echo -e "${GREEN}✅ Authenticated. Proceeding with command.${NC}"
}

# Find the real binary (bypassing our wrapper)
find_real_binary() {
    local cli="$1"
    # Remove guard dir from PATH and find the real binary
    local real_path
    real_path=$(
        PATH=$(echo "$PATH" | tr ':' '\n' | grep -v "$GUARD_DIR" | tr '\n' ':')
        command -v "$cli" 2>/dev/null
    )
    echo "${real_path:-$cli}"
}

# ─── Install/Uninstall ────────────────────────────────────────────────────

install_guards() {
    local target_dir="${1:-$GUARD_DIR}"
    local quiet="${BLASTSHIELD_GUARD_INSTALL_QUIET:-0}"
    mkdir -p "$target_dir"

    if [[ "$quiet" != "1" ]]; then
        echo "Installing blastshield-guard wrappers in $target_dir"
        echo ""
    fi

    local group cli patterns real_binary
    for group in $READONLY_PATTERNS; do
        cli="${group%%:*}"
        patterns="${group#*:}"

        local wrapper="$target_dir/$cli"
        real_binary=$(
            PATH=$(echo "$PATH" | tr ':' '\n' | grep -v "$target_dir" | tr '\n' ':')
            command -v "$cli" 2>/dev/null || echo ""
        )

        if [[ -z "$real_binary" ]]; then
            [[ "$quiet" == "1" ]] || echo "  ⏭  $cli — not found on system, skipping"
            continue
        fi

        # Create wrapper script
        cat > "$wrapper" << WRAPPER
#!/usr/bin/env bash
# blastshield-guard wrapper for $cli
# Auto-generated — do not edit
source "$GUARD_DIR/blastshield-guard"

cli="$cli"
args=("\$@")

if is_mutating "\$cli" "\${args[@]}"; then
    require_auth "\$cli" "\${args[@]}"
fi

exec "$real_binary" "\$@"
WRAPPER
        chmod +x "$wrapper"

        # Get count of read-only vs mutating patterns for display
        local ro_count mut_count
        ro_count=$(echo "$patterns" | tr ',' '\n' | wc -l | tr -d ' ')
        local mut_patterns
        mut_patterns=$(get_mutating_patterns "$cli" 2>/dev/null || echo "")
        mut_count=$(echo "$mut_patterns" | tr ',' '\n' | wc -l | tr -d ' ')

        [[ "$quiet" == "1" ]] || echo "  ✅ $cli → $real_binary ($ro_count read-only, $mut_count guarded)"
    done

    if [[ "$quiet" != "1" ]]; then
        echo ""
        echo "Add to your PATH (before real CLIs):"
        echo "  export PATH=\"$target_dir:\$PATH\""
        echo ""
        echo "For AI agents, add to their environment config."
    fi
}

uninstall_guards() {
    local target_dir="${1:-$GUARD_DIR}"
    echo "Removing blastshield-guard wrappers from $target_dir"

    local group cli
    for group in $READONLY_PATTERNS; do
        cli="${group%%:*}"
        local wrapper="$target_dir/$cli"
        if [[ -f "$wrapper" ]]; then
            rm "$wrapper"
            echo "  🗑  $cli"
        fi
    done
    echo "Done. Remove from PATH if needed."
}

# ─── Main ─────────────────────────────────────────────────────────────────

# If called directly (not sourced), handle subcommands
main_guard() {
    case "${1:-}" in
        install)
            shift
            install_guards "$@"
            ;;
        uninstall)
            shift
            uninstall_guards "$@"
            ;;
        list)
            echo "Guarded CLIs — read-only (auto-allow) vs mutating (requires auth):"
            echo ""
            local group cli ro_patterns mut_patterns
            for group in $READONLY_PATTERNS; do
                cli="${group%%:*}"
                ro_patterns="${group#*:}"
                mut_patterns=$(get_mutating_patterns "$cli" 2>/dev/null || echo "(none)")
                echo "  $cli"
                echo "    ✅ Read-only:  $(echo "$ro_patterns" | tr ',' '  ')"
                echo "    🔒 Mutating:   $(echo "$mut_patterns" | tr ',' '  ')"
                echo ""
            done
            ;;
        check)
            # Check if a specific command would be blocked
            shift
            local cli="${1:-}"
            [[ -z "$cli" ]] && { echo "Usage: blastshield-guard check <cli> [args...]"; exit 1; }
            shift
            if is_readonly "$cli" "$@"; then
                echo "ALLOWED (read-only): $cli $*"
                exit 0
            elif is_mutating "$cli" "$@"; then
                echo "BLOCKED (mutating — requires auth): $cli $*"
                exit 1
            else
                echo "UNGUARDED: $cli $*"
                exit 0
            fi
            ;;
        -h|--help|help)
            cat <<'HELP'
blastshield-guard — Command-level guard for mutating cloud CLI subcommands

PHILOSOPHY:
    Only read-only operations pass through automatically.
    ALL mutating commands require biometric/password authentication.
    The AI agent should prompt the user to run mutating commands manually.

USAGE:
    blastshield-guard install [DIR]    Install wrapper scripts to DIR
    blastshield-guard uninstall [DIR]  Remove wrapper scripts
    blastshield-guard list            List guarded CLIs and patterns
    blastshield-guard check CLI ARGS  Check if a command would be blocked
    blastshield-guard help            Show this help

GUARDED CLIS:
    terraform:  apply, destroy, import, taint → blocked
                init, plan, fmt, validate, show → allowed
    gcloud:     delete, create, deploy, update → blocked
                list, describe, get, status → allowed
    aws:        delete, create, put, terminate → blocked
                describe-, list-, get- → allowed
    az:         delete, create, update, deploy → blocked
                list, show, version → allowed
    kubectl:    apply, create, delete, exec → blocked
                get, describe, logs, top → allowed
    gh:         delete, merge, close, edit → blocked
                list, view, clone, fork → allowed
    helm:       install, upgrade, delete → blocked
                list, status, history, show → allowed

HOW IT WORKS:
    1. Install creates wrapper scripts in a directory
    2. Prepend that directory to PATH
    3. Wrappers check subcommand against read-only patterns
    4. Read-only commands pass through immediately
    5. Mutating commands require Touch ID / sudo password
    6. Default deny: if subcmd isn't in read-only list → blocked

PAIR WITH SANDBOX-EXEC:
    blastshield-guard handles command-argument filtering
    sandbox-exec (blastshield) handles filesystem/process/network filtering
    Use both together for defense in depth.
HELP
            ;;
        *)
            echo "Unknown command: ${1:-}"
            echo "Try: blastshield-guard help"
            exit 1
            ;;
    esac
}

# Run main_guard only when executed directly (not sourced)
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main_guard "$@"
fi
